# App home override. New name first, legacy alias still supported.
BONSAI_DESK_HOME=
PRISM_LAUNCHER_HOME=

# Prism runtime configuration
PRISM_LLAMA_SERVER_PATH=
PRISM_LLAMA_CPP_ZIP_URL=
PRISM_LLAMA_RELEASE_TAG=prism-b8194-1179bfc
PRISM_LLAMA_ASSET_SUFFIX=1179bfc
PRISM_LLAMA_RELEASE_BASE=https://github.com/PrismML-Eng/llama.cpp/releases/download

# Bonsai model configuration
PRISM_MODEL_URL=https://huggingface.co/prism-ml/Bonsai-8B-gguf/resolve/main/Bonsai-8B.gguf?download=true
PRISM_MODEL_FILENAME=Bonsai-8B.gguf
PRISM_BONSAI_MODEL_SIZE=8B

# Runtime endpoint
PRISM_RUNTIME_HOST=127.0.0.1
PRISM_RUNTIME_PORT=8080

# Frontend API base override for nondefault deployments
VITE_API_BASE_URL=
